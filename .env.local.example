# MySQL bağlantısı
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=outflow

# JWT imzalama anahtarı — production'da uzun, rastgele bir değer kullanın
JWT_SECRET=degistir-uzun-rastgele-bir-secret

# CORS — virgülle ayrılmış izinli origin'ler, ya da tüm origin'ler için *
# (React Native native istemci için CORS gerekmez; web/test için gereklidir)
CORS_ORIGIN=*

# E-posta gönderimi (şifre sıfırlama OTP) — SMTP.
# SMTP_HOST/SMTP_USER/SMTP_PASS boşsa kod gönderilmez, sunucu log'una yazılır (yalnızca geliştirme).
SMTP_HOST=
SMTP_PORT=587
# SMTP_SECURE: 465 portu için true, 587/25 (STARTTLS) için false. Boş bırakılırsa porttan tahmin edilir.
SMTP_SECURE=
SMTP_USER=outflow@yasinakbulut.dev
SMTP_PASS=
EMAIL_FROM=Outflow <outflow@yasinakbulut.dev>
