# MySQL bağlantısı
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=outflow

# JWT imzalama anahtarı — production'da uzun, rastgele bir değer kullanın
JWT_SECRET=degistir-uzun-rastgele-bir-secret

# CORS — virgülle ayrılmış izinli origin'ler, ya da tüm origin'ler için *
# (React Native native istemci için CORS gerekmez; web/test için gereklidir)
CORS_ORIGIN=*
